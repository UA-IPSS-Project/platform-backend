{
  "realm": "florinhas",
  "enabled": true,
  "displayName": "Florinhas do Vouga",
  "loginTheme": "florinhas",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "SECRETARIA", "description": "Funcionário administrativo" },
      { "name": "BALNEARIO", "description": "Funcionário do balneário social" },
      { "name": "ESCOLA", "description": "Funcionário da escola" },
      { "name": "INTERNO", "description": "Funcionário de serviços internos" },
      { "name": "UTENTE", "description": "Utente/cliente da IPSS" }
    ]
  },
  "clients": [
    {
      "clientId": "florinhas-frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "https://localhost:3443/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "https://localhost:3443",
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "florinhas-gateway",
      "enabled": true,
      "publicClient": false,
      "secret": "florinhas-gateway-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false
    }
  ],
  "clientScopes": [
    {
      "name": "openid",
      "protocol": "openid-connect"
    },
    {
      "name": "profile",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "secretaria@florinhasdovouga.pt",
      "email": "secretaria@florinhasdovouga.pt",
      "firstName": "Funcionário",
      "lastName": "Secretaria",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "sec123", "temporary": false }],
      "realmRoles": ["SECRETARIA"]
    },
    {
      "username": "balneario@florinhasdovouga.pt",
      "email": "balneario@florinhasdovouga.pt",
      "firstName": "Funcionário",
      "lastName": "Balneário",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "bal123", "temporary": false }],
      "realmRoles": ["BALNEARIO"]
    },
    {
      "username": "escola@florinhasdovouga.pt",
      "email": "escola@florinhasdovouga.pt",
      "firstName": "Funcionário",
      "lastName": "Escola",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "esc123", "temporary": false }],
      "realmRoles": ["ESCOLA"]
    },
    {
      "username": "dpo@florinhasdovouga.pt",
      "email": "dpo@florinhasdovouga.pt",
      "firstName": "Encarregado",
      "lastName": "Proteção Dados",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "dpo123", "temporary": false }],
      "realmRoles": ["SECRETARIA"]
    }
  ]
}
